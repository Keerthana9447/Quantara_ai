{
  "name": "quantara-ai",
  "version": "1.0.0",
  "description": "Quantara AI — AI-Powered Collateral Valuation & Resale Liquidity Engine",
  "scripts": {
    "dev": "concurrently --kill-others --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node scripts/run_backend.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "concurrently --kill-others --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node scripts/run_backend.js --no-reload",
    "start:frontend": "cd frontend && npm run start",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  }
}
