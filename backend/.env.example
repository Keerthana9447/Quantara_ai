# Quantara AI — Backend Environment
# Copy to .env and edit

# Database — SQLite (default, zero config)
DATABASE_URL=sqlite+aiosqlite:///./quantara.db

# Database — PostgreSQL (uncomment to use)
# DATABASE_URL=postgresql+asyncpg://quantara:quantara_pass@localhost:5432/quantara_db

# JWT
SECRET_KEY=quantara-change-this-secret-key-min-32-characters!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI (optional — enables real GPT-4o explanations)
OPENAI_API_KEY=

# App
DEBUG=false
